{
  "name": "@youin/extension",
  "displayName": "Youin",
  "version": "0.0.1",
  "description": "A visual feedback layer for the live web. Click any element, leave a comment, ship a ticket — without leaving the browser.",
  "author": "opmarq@gmail.com",
  "scripts": {
    "dev": "plasmo dev --src-path=.",
    "build": "plasmo build --src-path=.",
    "package": "plasmo package --src-path=."
  },
  "dependencies": {
    "@supabase/supabase-js": "2.105.3",
    "@youin/design-tokens": "workspace:*",
    "@youin/domain": "workspace:*",
    "@youin/i18n": "workspace:*",
    "html-to-image": "^1.11.13",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.17",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "storage",
      "tabs"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "externally_connectable": {
      "matches": [
        "http://localhost:3000/*",
        "https://youin.dev/*",
        "https://www.youin.dev/*"
      ]
    }
  }
}
