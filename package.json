{
  "name": "youin",
  "version": "0.0.1",
  "private": true,
  "description": "A visual feedback layer for the live web. Click any element, leave a comment, ship a ticket — without leaving the browser.",
  "author": "opmarq@gmail.com",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build:tokens": "pnpm --filter @youin/design-tokens build",
    "dev:tokens": "pnpm --filter @youin/design-tokens dev",
    "dev:extension": "pnpm --filter @youin/extension dev",
    "build:extension": "pnpm --filter @youin/extension build",
    "package:extension": "pnpm --filter @youin/extension package",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "lint:design": "bash scripts/design-lint.sh"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
